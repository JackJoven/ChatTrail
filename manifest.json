{
  "manifest_version": 3,
  "name": "ChatTrail",
  "version": "0.2.0",
  "description": "Timeline navigation for AI chat platforms.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://doubao.com/*",
    "https://www.doubao.com/*",
    "https://*.doubao.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://doubao.com/*",
        "https://www.doubao.com/*",
        "https://*.doubao.com/*"
      ],
      "js": [
        "src/content/timeline.js",
        "src/content/enhancements.js"
      ],
      "css": [
        "src/content/timeline.css",
        "src/content/enhancements.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_page": "src/options/options.html",
  "action": {
    "default_title": "ChatTrail",
    "default_popup": "src/popup/popup.html"
  }
}
